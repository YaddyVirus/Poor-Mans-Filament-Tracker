# Copy to .env and fill in your own values. .env is gitignored — never commit it.

# Direct printer connection (all three shown on the printer's screen:
# Settings -> Network / Device / WLAN)
PRINTER_HOST=192.168.1.100
PRINTER_SERIAL=00000000000000
PRINTER_ACCESS_CODE=00000000

# Home Assistant sync + spool selector (optional but recommended)
HA_URL=http://192.168.1.50:8123
HA_TOKEN=your-ha-long-lived-access-token

# Behavior
DEDUCT_ON_FAILED=true
AUTO_SELECT_SPOOL=true
